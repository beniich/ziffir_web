# ── NEON POSTGRESQL (Production) ────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?channel_binding=require&sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Auth — Générer avec: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars-abc123def
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars-xyz789ghi
JWT_INVITE_SECRET=change-me-in-production-min-32-chars-inv456jkl

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=true

# Frontend
FRONTEND_URL=https://your-app.vercel.app
PORT=3000

# Firebase / Google Auth
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Admin SDK
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# SMTP (invitations par email)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx
SMTP_FROM=noreply@yourapp.com

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 2FA
TOTP_ISSUER=YourApp
TOTP_LABEL=YourApp Admin
