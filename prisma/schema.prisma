generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  CLIENT
  HOTEL
  ADMIN
}

enum HotelRole {
  OWNER
  MANAGER
  SOMMELIER
  CONCIERGE
  RECEPTION
  HOUSEKEEPING
  KITCHEN
  STAFF
  VIEWER
}

enum Plan {
  FREE_TRIAL
  FREE
  PREMIUM
  PLATINIUM
  GOLDEN
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  INCOMPLETE
}

// ============================================================================
// IDENTITÉ : User
// ============================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String   @default("")
  name          String?
  displayName   String?
  phone         String?
  avatarUrl     String?

  // Rôle global plateforme
  role          UserRole @default(CLIENT)

  // État
  isActive         Boolean  @default(true)
  emailVerified    Boolean  @default(false)
  emailVerifiedAt  DateTime?

  // 2FA
  totpSecret       String?
  totpEnabled      Boolean  @default(false)

  // Sécurité
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  passwordChangedAt DateTime @default(now())

  // Préférences
  language      String   @default("fr")
  timezone      String   @default("Europe/Paris")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions            UserSession[]
  memberships         HotelMembership[]
  pushSubscriptions   PushSubscription[]
  invitationsSent     HotelInvitation[]   @relation("InvitedBy")
  hotelOwnerships     Hotel[]             @relation("HotelOwner")
  updatedSuites       SuiteState[]
  ordersPlaced        RoomOrder[]         @relation("OrderPlacedBy")
  ordersAsChef        RoomOrder[]         @relation("OrderChef")
  ordersAsServer      RoomOrder[]         @relation("OrderServer")
  statusEvents        OrderStatusEvent[]
  hostedArrivals      Arrival[]           @relation("ArrivalHost")
  createdArrivals     Arrival[]           @relation("ArrivalCreatedBy")
  assignedTasks       ArrivalTask[]       @relation("TaskAssigned")
  arrivalStatusEvents ArrivalStatusEvent[]
  taskEvents          TaskEvent[]

  @@index([email])
  @@index([role, isActive])
}

// ============================================================================
// HÔTEL (TENANT) + ABONNEMENT
// ============================================================================

model Hotel {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique @default("")
  description String?

  // Propriétaire
  ownerId     String  @default("")
  owner       User    @relation("HotelOwner", fields: [ownerId], references: [id])

  // Branding
  logoUrl      String?
  primaryColor String?

  // Adresse
  address  String?
  city     String?
  country  String?
  timezone String  @default("Europe/Paris")
  currency String  @default("EUR")

  // ── Abonnement ──────────────────────────────────────────────────────────
  plan                Plan               @default(FREE_TRIAL)
  trialEndsAt         DateTime?
  subscriptionId      String?            @unique
  stripeCustomerId    String?            @unique
  subscriptionStatus  SubscriptionStatus @default(TRIALING)
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  cancelledAt         DateTime?

  // Limites par plan
  maxRooms       Int @default(5)
  maxUsers       Int @default(3)
  maxSuiteStates Int @default(5)

  // État
  isActive        Boolean   @default(true)
  suspendedAt     DateTime?
  suspendedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships   HotelMembership[]
  invitations   HotelInvitation[]
  suites        SuiteState[]
  menuItems     MenuItem[]
  orders        RoomOrder[]
  aiRules       AiRule[]
  tokenQuotas   ApiTokenQuota[]
  arrivals      Arrival[]
  apiKeys       ApiKey[]

  @@index([ownerId])
  @@index([plan, isActive])
  @@index([stripeCustomerId])
  @@index([subscriptionId])
}

// ============================================================================
// MEMBERSHIP (User ↔ Hotel avec rôle)
// ============================================================================

model HotelMembership {
  id      String    @id @default(cuid())
  hotelId String
  userId  String
  role    HotelRole @default(STAFF)

  // Permissions custom (JSON array) ex: '["vault.view","vault.edit"]'
  permissions String @default("[]")

  isActive    Boolean   @default(true)
  invitedAt   DateTime  @default(now())
  joinedAt    DateTime?
  removedAt   DateTime?
  invitedById String?

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hotelId, userId])
  @@index([userId, isActive])
  @@index([hotelId, role])
}

// ============================================================================
// INVITATION (avant qu'un User existe)
// ============================================================================

model HotelInvitation {
  id           String    @id @default(cuid())
  hotelId      String
  email        String
  proposedRole HotelRole
  token        String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  invitedById  String
  message      String?
  createdAt    DateTime  @default(now())

  invitedBy User  @relation("InvitedBy", fields: [invitedById], references: [id])
  hotel     Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, email])
  @@index([token])
  @@index([expiresAt])
}

// ============================================================================
// SESSION (refresh token tracking)
// ============================================================================

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  activeHotelId String?
  userAgent     String?
  ipAddress     String?
  refreshToken  String    @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  country       String?
  city          String?
  totpVerified  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([refreshToken])
  @@index([expiresAt])
}

// ============================================================================
// API KEYS (intégrations externes)
// ============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  hotelId     String
  name        String
  prefix      String    @unique
  hashedKey   String
  scopes      String    @default("[]") // JSON array
  allowedIps  String    @default("[]") // JSON array
  rateLimit   Int       @default(1000)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([prefix])
}

// ============================================================================
// Suite Controls
// ============================================================================

model Room {
  id     String @id @default(cuid())
  number String
  floor  Int?
  type   String

  suites   SuiteState[]
  orders   RoomOrder[]
  arrivals Arrival[]
}

model SuiteState {
  id              String   @id @default(cuid())
  hotelId         String
  roomId          String
  temperatureC    Float    @default(20.0)
  humidity        Float?
  lightLevel      Int      @default(50)
  curtainsOpen    Boolean  @default(false)
  musicPlaying    Boolean  @default(false)
  musicTrackId    String?
  scene           String   @default("IDLE")
  isOccupied      Boolean  @default(false)
  guestId         String?
  guestCheckInAt  DateTime?
  guestCheckOutAt DateTime?
  doNotDisturb    Boolean  @default(false)
  maintenanceMode Boolean  @default(false)
  version         Int      @default(0)
  lastUpdatedAt   DateTime @updatedAt
  lastUpdatedById String?

  room          Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  hotel         Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  lastUpdatedBy User?  @relation(fields: [lastUpdatedById], references: [id])
  controlEvents SuiteControlEvent[]

  @@unique([hotelId, roomId])
  @@index([hotelId])
  @@index([roomId])
}

model SuiteControlEvent {
  id            String   @id @default(cuid())
  hotelId       String
  suiteStateId  String
  action        String
  previousValue String?
  newValue      String
  actorId       String?
  actor         String
  source        String
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  suiteState SuiteState @relation(fields: [suiteStateId], references: [id], onDelete: Cascade)

  @@index([hotelId, createdAt])
  @@index([suiteStateId])
}

// ============================================================================
// Membership (ancienne version, gardée pour compat. migrations existantes)
// ============================================================================

model Membership {
  id      String @id @default(cuid())
  userId  String
  hotelId String
  role    String // OWNER, MANAGER, STAFF, CLIENT

  @@unique([userId, hotelId])
  @@index([hotelId, role])
}

// ============================================================================
// Room Service
// ============================================================================

model MenuItem {
  id           String   @id @default(cuid())
  hotelId      String
  category     String
  name         String
  description  String?
  imageUrl     String?
  priceCents   Int
  currency     String   @default("EUR")
  prepMinutes  Int      @default(15)
  isAvailable  Boolean  @default(true)
  isVegan      Boolean  @default(false)
  isVegetarian Boolean  @default(false)
  isGlutenFree Boolean  @default(false)
  sortOrder    Int      @default(0)
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel      Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([hotelId, category])
  @@index([hotelId, isAvailable])
}

model RoomOrder {
  id               String   @id @default(cuid())
  hotelId          String
  roomId           String
  orderNumber      String   @unique
  guestName        String
  guestId          String?
  placedById       String?
  placedBySource   String   @default("GUEST_PORTAL")
  status           String   @default("PENDING")
  previousStatus   String?
  assignedChefId   String?
  assignedServerId String?
  placedAt         DateTime @default(now())
  acknowledgedAt   DateTime?
  startedPrepAt    DateTime?
  readyAt          DateTime?
  deliveredAt      DateTime?
  estimatedReadyAt DateTime?
  promisedReadyAt  DateTime?
  subtotalCents    Int      @default(0)
  serviceFeeCents  Int      @default(0)
  taxCents         Int      @default(0)
  totalCents       Int      @default(0)
  currency         String   @default("EUR")
  guestNotes       String?
  kitchenNotes     String?
  serverNotes      String?
  rating           Int?
  feedback         String?
  ratedAt          DateTime?
  version          Int      @default(0)

  hotel          Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room           Room              @relation(fields: [roomId], references: [id])
  placedBy       User?             @relation("OrderPlacedBy", fields: [placedById], references: [id])
  assignedChef   User?             @relation("OrderChef", fields: [assignedChefId], references: [id])
  assignedServer User?             @relation("OrderServer", fields: [assignedServerId], references: [id])
  items          OrderItem[]
  statusHistory  OrderStatusEvent[]

  @@index([hotelId, status])
  @@index([hotelId, placedAt])
  @@index([roomId, status])
  @@index([assignedChefId, status])
  @@index([assignedServerId, status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  menuItemId  String?
  name        String
  quantity    Int     @default(1)
  priceCents  Int
  notes       String?
  order       RoomOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
}

model OrderStatusEvent {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String?
  toStatus   String
  actorId    String?
  actorType  String   @default("system")
  reason     String?
  metadata   String?
  createdAt  DateTime @default(now())

  order RoomOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User?     @relation(fields: [actorId], references: [id])

  @@index([orderId, createdAt])
}

// ============================================================================
// Push & Notifications
// ============================================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// Audit Log
// ============================================================================

model AuditLog {
  id           String   @id @default(cuid())
  hotelId      String?
  eventType    String
  actorId      String?
  actorType    String
  resourceType String?
  resourceId   String?
  action       String
  metadata     String?
  ipAddress    String?
  userAgent    String?
  previousHash String   @default("GENESIS")
  hash         String
  createdAt    DateTime @default(now())

  @@index([hotelId, createdAt])
  @@index([actorId])
  @@index([eventType])
}

// ============================================================================
// AI Rules
// ============================================================================

model AiRule {
  id        String   @id @default(cuid())
  hotelId   String
  module    String
  trigger   String
  action    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, module])
}

// ============================================================================
// API Token Quotas
// ============================================================================

model ApiTokenQuota {
  id           String   @id @default(cuid())
  hotelId      String
  actorId      String
  actorType    String
  dailyLimit   Int      @default(1000)
  consumedToday Int     @default(0)
  lastResetAt  DateTime @default(now())
  isSuspended  Boolean  @default(false)
  suspendReason String?
  suspendedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, actorType, actorId], name: "hotelId_actorType_actorId")
  @@index([hotelId])
}

// ============================================================================
// Arrivals VIP
// ============================================================================

enum VipLevel {
  CLASSIC
  SILVER
  GOLD
  DIAMOND
  AMBASSADOR
}

enum ArrivalStatus {
  SCHEDULED
  CONFIRMED
  EN_ROUTE
  ARRIVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum TransportMode {
  FLIGHT
  TRAIN
  PRIVATE_CAR
  HELICOPTER
  YACHT
  WALK_IN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TeamType {
  RECEPTION
  CONCIERGE
  HOUSEKEEPING
  RESTAURANT
  SPA
  VALET
  BELL_SERVICE
  TRANSPORT
  SECURITY
  MANAGEMENT
  EXTERNAL
}

enum TaskStatus {
  PENDING
  BLOCKED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

model Arrival {
  id                   String        @id @default(cuid())
  hotelId              String
  externalRef          String?
  confirmationNumber   String?       @unique
  guestName            String
  guestEmail           String?
  guestPhone           String?
  guestLanguage        String        @default("fr")
  vipLevel             VipLevel      @default(CLASSIC)
  status               ArrivalStatus @default(SCHEDULED)
  previousStatus       ArrivalStatus?
  scheduledArrivalAt   DateTime
  scheduledDepartureAt DateTime?
  actualArrivalAt      DateTime?
  actualDepartureAt    DateTime?
  transportMode        TransportMode
  flightNumber         String?
  flightOrigin         String?
  flightEta            DateTime?
  driverName           String?
  driverPhone          String?
  driverVehicle        String?
  driverEta            DateTime?
  driverAssignedAt     DateTime?
  roomId               String?
  suiteReadyBy         DateTime?
  suiteReadyAt         DateTime?
  suiteNotes           String?
  welcomeAmenity       String?
  dietaryNotes         String?
  specialRequests      String?
  meetingPoint         String?
  hostUserId           String?
  estimatedRevenueCents Int?
  currency             String        @default("EUR")
  riskLevel            RiskLevel     @default(LOW)
  riskNotes            String?
  notes                String?
  version              Int           @default(0)
  createdById          String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  hotel           Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room            Room?               @relation(fields: [roomId], references: [id])
  host            User?               @relation("ArrivalHost", fields: [hostUserId], references: [id])
  createdBy       User                @relation("ArrivalCreatedBy", fields: [createdById], references: [id])
  tasks           ArrivalTask[]
  statusHistory   ArrivalStatusEvent[]
  externalUpdates ExternalUpdate[]

  @@index([hotelId, scheduledArrivalAt])
  @@index([hotelId, status])
  @@index([roomId])
}

model ArrivalTask {
  id              String     @id @default(cuid())
  arrivalId       String
  hotelId         String
  team            TeamType
  title           String
  description     String?
  dueAt           DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  assignedUserId  String?
  status          TaskStatus @default(PENDING)
  blockedBy       String     @default("[]")
  completedById   String?
  completionNotes String?
  evidenceUrl     String?
  priority        Int        @default(0)
  isCritical      Boolean    @default(false)
  version         Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  arrival      Arrival     @relation(fields: [arrivalId], references: [id], onDelete: Cascade)
  assignedUser User?       @relation("TaskAssigned", fields: [assignedUserId], references: [id])
  events       TaskEvent[]

  @@index([arrivalId])
  @@index([hotelId, status])
  @@index([team, status])
  @@index([assignedUserId, status])
}

model ArrivalStatusEvent {
  id         String        @id @default(cuid())
  arrivalId  String
  fromStatus ArrivalStatus?
  toStatus   ArrivalStatus
  actorId    String?
  actorType  String
  reason     String?
  metadata   String?
  createdAt  DateTime      @default(now())

  arrival Arrival @relation(fields: [arrivalId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([arrivalId, createdAt])
}

model TaskEvent {
  id         String     @id @default(cuid())
  taskId     String
  fromStatus TaskStatus?
  toStatus   TaskStatus
  actorId    String?
  notes      String?
  metadata   String?
  createdAt  DateTime   @default(now())

  task  ArrivalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User?       @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
}

model ExternalUpdate {
  id          String   @id @default(cuid())
  arrivalId   String
  source      String
  updateType  String
  payload     String
  processedAt DateTime?
  createdAt   DateTime @default(now())

  arrival Arrival @relation(fields: [arrivalId], references: [id], onDelete: Cascade)

  @@index([arrivalId, createdAt])
  @@index([source, processedAt])
}

// ============================================================================
// BOOKING — Réservations publiques (widget site marketing)
// ============================================================================

model Booking {
  id               String   @id @default(cuid())
  hotelId          String
  roomId           String
  confirmationCode String   @unique
  status           String   @default("PENDING_CONFIRMATION")
  // Guest info (public, pas forcément un user enregistré)
  guestFirstName   String
  guestLastName    String
  guestEmail       String
  guestPhone       String?
  specialRequests  String?
  // Séjour
  checkInDate      DateTime
  checkOutDate     DateTime
  nights           Int
  guestsCount      Int      @default(1)
  promoCode        String?
  // Pricing (calculé côté serveur)
  subtotalCents    Int?
  taxCents         Int?
  totalCents       Int?
  currency         String   @default("EUR")
  // Refs
  externalRef      String?
  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  confirmedAt      DateTime?
  cancelledAt      DateTime?

  @@index([hotelId, checkInDate])
  @@index([guestEmail])
  @@index([status])
}

// ============================================================================
// NEWSLETTER — Inscriptions newsletter (double opt-in)
// ============================================================================

model NewsletterSubscriber {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String?
  interests         String    @default("[]") // JSON array
  source            String    @default("unknown")
  confirmationToken String?   @unique
  confirmedAt       DateTime?
  unsubscribedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([confirmationToken])
}
